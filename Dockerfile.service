FROM node:18-alpine

WORKDIR /app

RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    git \
    curl

COPY package*.json ./

RUN npm install -g typescript ts-node

RUN npm install

COPY shared ./shared
COPY services ./services

RUN tsc --noEmit || true

ENV NODE_ENV=production

CMD ["node", "dist/services/${SERVICE_NAME}/index.js"]
